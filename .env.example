# ---------------------------------------------------------------
# جَلّي — server-side environment variables (Vercel → Settings →
# Environment Variables). These are SERVER-ONLY secrets:
#   * NEVER put the real key in index.html, JavaScript, or GitHub.
#   * NEVER use client-exposed prefixes (VITE_, NEXT_PUBLIC_, ...).
# Copy this file to .env for local `vercel dev` testing only.
# ---------------------------------------------------------------

# Required. Your Anthropic API key (server-side only).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional. Supported Anthropic model id; the server falls back to
# claude-sonnet-4-5 when unset. Change it here — never in frontend code.
ANTHROPIC_MODEL=claude-sonnet-4-5
